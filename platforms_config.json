{
  "platforms": {
    "linkedin": {
      "name": "LinkedIn",
      "base_url": "https://www.linkedin.com",
      "profile_url_pattern": "https://www.linkedin.com/in/{username}",
      "jobs_url_pattern": "https://www.linkedin.com/jobs/search/?keywords={keyword}&location={location}",
      "enabled": true,
      "scraper_type": "headless_browser",
      "timeout": 10,
      "selectors": {
        "profile_name": "h1.text-heading-xlarge",
        "headline": "div.text-body-medium",
        "about": "section[id='about'] p",
        "experience": "section[id='experience'] li",
        "skills": "section[id='skills'] li" ,
        "job_cards": "div.job-search-card",
        "job_title": "h3.base-search-card__title",
        "job_company": "h4.base-search-card__subtitle",
        "job_location": "span.job-search-card__location",
        "job_link": "a.base-card__full-link"
      },
      "api_method": "none",
      "requires_auth": false,
      "metadata": {
        "description": "LinkedIn profile scraping",
        "last_updated": "2025-06-01"
      }
    },
    "naukri": {
      "name": "Naukri",
      "base_url": "https://www.naukri.com",
      "profile_url_pattern": "https://www.naukri.com/mnjuser/profile/{user_id}",
       "jobs_url_pattern": "https://www.naukri.com/{keyword}-jobs-in-{location}",
      "enabled": true,
      "scraper_type": "http",
      "timeout": 8,
      "selectors": {
        "profile_name": "h1.fullName",
        "headline": "div.title",
        "about": "div.summaryText",
        "experience": "section.experience li",
        "skills": "section.skills .tagItem" ,
        "job_cards": "article.jobTuple",
        "job_title": "a.title",
        "job_company": "a.subTitle",
        "job_location": "li.location",
        "job_link": "a.title"
      },
      "api_method": "none",
      "requires_auth": false,
      "metadata": {
        "description": "Naukri profile scraping",
        "last_updated": "2025-06-01"
      }
    }
  },
  "scraper_config": {
    "headless_browser": {
      "timeout": 10,
      "wait_for_selector": true,
      "javascript_enabled": true
    },
    "http": {
      "timeout": 8,
      "follow_redirects": true,
      "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
    }
  }
}
